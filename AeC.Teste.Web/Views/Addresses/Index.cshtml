@model IReadOnlyList<AeC.Teste.Web.ViewModels.AddressListViewModel>

@{
    ViewData["Title"] = "Endereços";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Endereços</h2>

        <a asp-action="Create" class="btn btn-primary">
            Novo Endereço
        </a>
    </div>

    <table class="table table-striped table-hover">

        <thead>
            <tr>
                <th>CEP</th>
                <th>Rua</th>
                <th>Número</th>
                <th>Bairro</th>
                <th>Cidade</th>
                <th>Estado</th>
                <th>Usuário</th>
                <th width="180">Ações</th>
            </tr>
        </thead>

        <tbody>

        @foreach (var address in Model)
        {
            <tr>
                <td>@address.Cep</td>
                <td>@address.Street</td>
                <td>@address.Number</td>
                <td>@address.District</td>
                <td>@address.City</td>
                <td>@address.State</td>
                <td>@address.UserName</td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@address.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@address.Id"
                       class="btn btn-danger btn-sm">
                        Excluir
                    </a>
                </td>
            </tr>
        }

        </tbody>

    </table>

</div>
