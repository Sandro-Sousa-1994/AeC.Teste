@model AeC.Teste.Web.ViewModels.AddressEditViewModel

@{
    ViewData["Title"] = "Excluir Endereço";
}

<div class="container mt-4">

    <h2>Excluir Endereço</h2>

    <hr />

    <div class="alert alert-warning">
        <p><strong>Tem certeza que deseja excluir este endereço?</strong></p>
        <p>Esta ação não pode ser desfeita.</p>
    </div>

    <div class="card">
        <div class="card-body">
            <p><strong>CEP:</strong> @Model.Cep</p>
            <p><strong>Rua:</strong> @Model.Street, @Model.Number</p>
            @if (!string.IsNullOrEmpty(Model.Complement))
            {
                <p><strong>Complemento:</strong> @Model.Complement</p>
            }
            <p><strong>Bairro:</strong> @Model.District</p>
            <p><strong>Cidade:</strong> @Model.City</p>
            <p><strong>Estado:</strong> @Model.State</p>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">

        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">
            Sim, Excluir
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancelar
        </a>

    </form>

</div>
