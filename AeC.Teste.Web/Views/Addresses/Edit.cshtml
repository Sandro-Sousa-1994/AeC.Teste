@model AeC.Teste.Web.ViewModels.AddressEditViewModel

@{
    ViewData["Title"] = "Editar Endereço";
}

<div class="container mt-4">

    <h2>Editar Endereço</h2>

    <hr />

    <form asp-action="Edit" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Cep" class="form-label"></label>
            <div class="input-group">
                <input asp-for="Cep" class="form-control" id="cepInput" />
                <button type="button" class="btn btn-outline-secondary" id="searchCepBtn">
                    Buscar CEP
                </button>
            </div>
            <span asp-validation-for="Cep" class="text-danger"></span>
            <small id="cepMessage" class="d-block mt-2"></small>
        </div>

        <div class="mb-3">
            <label asp-for="Street" class="form-label"></label>
            <input asp-for="Street" class="form-control" />
            <span asp-validation-for="Street" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Number" class="form-label"></label>
            <input asp-for="Number" class="form-control" />
            <span asp-validation-for="Number" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Complement" class="form-label"></label>
            <input asp-for="Complement" class="form-control" />
            <span asp-validation-for="Complement" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="District" class="form-label"></label>
            <input asp-for="District" class="form-control" />
            <span asp-validation-for="District" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="City" class="form-label"></label>
            <input asp-for="City" class="form-control" />
            <span asp-validation-for="City" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="State" class="form-label"></label>
            <input asp-for="State" class="form-control" />
            <span asp-validation-for="State" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="UserId" class="form-label"></label>
            <select asp-for="UserId" asp-items="(IEnumerable<SelectListItem>)ViewBag.Users" class="form-select">
                <option value="">-- Selecione um usuário --</option>
            </select>
            <span asp-validation-for="UserId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">
            Salvar
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Voltar
        </a>

    </form>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById('searchCepBtn').addEventListener('click', async function() {
            const cep = document.getElementById('cepInput').value.trim();
            const messageEl = document.getElementById('cepMessage');

            if (!cep) {
                messageEl.textContent = 'Digite um CEP primeiro.';
                messageEl.className = 'text-danger d-block mt-2';
                return;
            }

            try {
                const response = await fetch(`/Addresses/GetAddressByCep?cep=${encodeURIComponent(cep)}`);
                const data = await response.json();

                if (data.success) {
                    document.getElementById('Street').value = data.street || '';
                    document.getElementById('District').value = data.district || '';
                    document.getElementById('City').value = data.city || '';
                    document.getElementById('State').value = data.state || '';

                    messageEl.textContent = 'CEP encontrado com sucesso!';
                    messageEl.className = 'text-success d-block mt-2';
                } else {
                    messageEl.textContent = data.message || 'CEP não encontrado. Verifique e tente novamente.';
                    messageEl.className = 'text-warning d-block mt-2';
                }
            } catch (error) {
                messageEl.textContent = 'Erro ao consultar CEP. Tente novamente.';
                messageEl.className = 'text-danger d-block mt-2';
                console.error('Erro:', error);
            }
        });

        document.getElementById('cepInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('searchCepBtn').click();
            }
        });
    </script>
}
