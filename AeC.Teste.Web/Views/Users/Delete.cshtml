@model AeC.Teste.Web.ViewModels.UserEditViewModel

@{
    ViewData["Title"] = "Excluir Usuário";
}

<div class="container mt-4">

    <h2>Excluir Usuário</h2>

    <hr />

    <div class="alert alert-warning">
        <p><strong>Tem certeza que deseja excluir este usuário?</strong></p>
        <p>Esta ação não pode ser desfeita.</p>
    </div>

    <div class="card">
        <div class="card-body">
            <p><strong>Nome:</strong> @Model.Name</p>
            <p><strong>Usuário:</strong> @Model.Username</p>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">

        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">
            Sim, Excluir
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancelar
        </a>

    </form>

</div>
